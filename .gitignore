# ==========================================
# C++ Build Outputs
# ==========================================
# Ignore the standard CMake build directories
build/
out/
bin/

# Ignore compiled executables and libraries
*.exe
*.out
*.app
*.o
*.obj
*.dll
*.dylib
*.so
*.a
*.lib

# ==========================================
# Windows & Visual Studio Junk
# ==========================================
.vs/
*.user
*.suo
*.db
*.sln
*.vcxproj
*.vcxproj.filters

# ==========================================
# macOS & Apple Junk
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
*.xcodeproj/
*.xcworkspace/

# ==========================================
# VS Code (Optional but recommended)
# ==========================================
.vscode/

# ==========================================
# Project Specific
# ==========================================
# Ignore any user-generated text files during testing, 
# but keep the required default data files in /resources
*.log

# Ignore ImGui local layout state
DataStructureVisualizer/imgui.ini

.cache/

# ==========================================
# LaTeX Junk
# ==========================================
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.toc
*.lof
*.lot
*.dvi
*.bcf
*.run.xml
